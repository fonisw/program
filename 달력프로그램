<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Todo Calendar</title>

  <style>
    body {
      margin: 0;
      padding: 20px;
      font-family: Arial, sans-serif;
      background: #f5f5f5;
    }

    h1 {
      text-align: center;
    }

    .calendar {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 12px;
      margin-top: 30px;
    }

    .day {
      background: white;
      border-radius: 12px;
      min-height: 120px;
      padding: 10px;
      cursor: pointer;
      position: relative;
      transition: 0.2s;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .day:hover {
      transform: scale(1.02);
    }

    .date {
      font-weight: bold;
      margin-bottom: 10px;
    }

    .todo-preview {
      font-size: 13px;
      margin-bottom: 4px;
    }

    .done {
      position: absolute;
      top: 10px;
      right: 10px;
      color: green;
      font-size: 20px;
    }

    /* 모달 */

    .modal {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);

      display: none;
      justify-content: center;
      align-items: center;
    }

    .modal-content {
      background: white;
      width: 320px;
      padding: 20px;
      border-radius: 12px;
    }

    input[type="text"] {
      width: 100%;
      padding: 10px;
      margin-bottom: 10px;
      box-sizing: border-box;
    }

    button {
      padding: 10px 14px;
      border: none;
      background: #007bff;
      color: white;
      border-radius: 8px;
      cursor: pointer;
    }

    button:hover {
      background: #0056b3;
    }

    .close-btn {
      background: #666;
      margin-top: 15px;
    }

    .close-btn:hover {
      background: #444;
    }

    .todo-item {
      margin-top: 10px;
    }
  </style>
</head>
<body>

  <h1>📅 Todo Calendar</h1>

  <div class="calendar" id="calendar"></div>

  <!-- 모달 -->
  <div class="modal" id="modal">
    <div class="modal-content">

      <h2 id="selectedDate"></h2>

      <input
        type="text"
        id="todoInput"
        placeholder="할 일을 입력하세요"
      >

      <button id="addBtn">추가</button>

      <div id="todoList"></div>

      <button
        class="close-btn"
        id="closeBtn"
      >
        닫기
      </button>

    </div>
  </div>

  <script>
    const calendar =
      document.getElementById("calendar");

    const modal =
      document.getElementById("modal");

    const selectedDateText =
      document.getElementById("selectedDate");

    const todoInput =
      document.getElementById("todoInput");

    const todoList =
      document.getElementById("todoList");

    const addBtn =
      document.getElementById("addBtn");

    const closeBtn =
      document.getElementById("closeBtn");

    let selectedDate = "";

    let todos =
      JSON.parse(localStorage.getItem("todos")) || {};

    function saveTodos() {
      localStorage.setItem(
        "todos",
        JSON.stringify(todos)
      );
    }

    function createCalendar() {

      calendar.innerHTML = "";

      for (let day = 1; day <= 31; day++) {

        const dateKey =
          `2026-05-${String(day).padStart(2, "0")}`;

        const dayDiv =
          document.createElement("div");

        dayDiv.className = "day";

        const tasks =
          todos[dateKey] || [];

        const completed =
          tasks.length > 0 &&
          tasks.every(task => task.done);

        dayDiv.innerHTML = `
          <div class="date">${day}일</div>

          ${completed ? `
            <div class="done">✅</div>
          ` : ""}

          ${tasks.slice(0,3).map(task => `
            <div class="todo-preview">
              ${task.done ? "✔️" : "⬜"}
              ${task.text}
            </div>
          `).join("")}
        `;

        dayDiv.addEventListener("click", () => {
          openModal(dateKey);
        });

        calendar.appendChild(dayDiv);
      }
    }

    function openModal(date) {

      selectedDate = date;

      selectedDateText.textContent = date;

      modal.style.display = "flex";

      renderTodos();
    }

    function closeModal() {
      modal.style.display = "none";
    }

    function renderTodos() {

      todoList.innerHTML = "";

      const tasks =
        todos[selectedDate] || [];

      tasks.forEach((task, index) => {

        const div =
          document.createElement("div");

        div.className = "todo-item";

        div.innerHTML = `
          <label>
            <input
              type="checkbox"
              ${task.done ? "checked" : ""}
            >
            ${task.text}
          </label>
        `;

        const checkbox =
          div.querySelector("input");

        checkbox.addEventListener("change", () => {

          todos[selectedDate][index].done =
            checkbox.checked;

          saveTodos();

          renderTodos();

          createCalendar();
        });

        todoList.appendChild(div);
      });
    }

    function addTodo() {

      const text =
        todoInput.value.trim();

      if (!text) return;

      if (!todos[selectedDate]) {
        todos[selectedDate] = [];
      }

      todos[selectedDate].push({
        text,
        done: false
      });

      todoInput.value = "";

      saveTodos();

      renderTodos();

      createCalendar();
    }

    addBtn.addEventListener("click", addTodo);

    closeBtn.addEventListener("click", closeModal);

    createCalendar();
  </script>

</body>
</html>
